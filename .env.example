AIQRA_HOST=0.0.0.0
AIQRA_PORT=8000
AIQRA_LOG_LEVEL=INFO
AIQRA_CONFIG=configs/base.yaml

# Local Level 1 registry. This is not a broker, market-data, or live-trading key.
AIQRA_EXPERIMENT_REGISTRY=results/experiments.sqlite

# Internal API keys use comma-separated key:role entries.
# Roles: viewer can read metrics/runs/reports/signals; researcher can also run experiments.
AIQRA_API_KEYS=local-viewer-change-me:viewer,local-researcher-change-me:researcher
